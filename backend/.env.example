# TruckLog Pro Backend - Environment Variables
# Copy to .env and set values. Never commit .env to git.
# Usage: cp .env.example .env
#
# Safe defaults for local Mac dev (PostgreSQL on localhost:5432).

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT (required) - use a long random string in production (min 32 chars)
JWT_SECRET=your-super-secret-key-change-in-production

# PostgreSQL - defaults work for local Mac (host=localhost, port=5432)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trucklog_pro
# SSL: with DATABASE_URL we use SSL by default. For local Postgres that requires SSL use DB_SSL=true; to disable SSL use DB_SSL=false.
# DB_SSL=true

# Or use a single URL (overrides individual vars; SSL is used by default for cloud URLs)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trucklog_pro

# Optional: use MySQL instead of Postgres
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=trucklog_pro

# CORS - comma-separated origins (optional)
# CORS_ORIGINS=http://localhost:3000,http://localhost:19006
